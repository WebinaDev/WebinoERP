{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/login",
        "http://localhost:3000/dashboard",
        "http://localhost:3000/dashboard/crm/leads",
        "http://localhost:3000/dashboard/finance/journals",
        "http://localhost:3000/dashboard/scm/inbound",
        "http://localhost:3000/dashboard/admin/hosting-infra"
      ],
      "numberOfRuns": 1,
      "puppeteerScript": "./scripts/lhci-auth.mjs",
      "settings": {
        "preset": "desktop",
        "formFactor": "mobile",
        "screenEmulation": {
          "mobile": true
        }
      }
    },
    "assert": {
      "assertions": {
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "categories:performance": ["warn", { "minScore": 0.5 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
