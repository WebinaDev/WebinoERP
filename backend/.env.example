APP_NAME=WebinoERM
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Tehran

APP_LOCALE=fa
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fa_IR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker Compose defaults (see ../docker-compose.yml)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=webina_crm
DB_USERNAME=postgres
DB_PASSWORD=postgres

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=webino_

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@webino.local"
MAIL_FROM_NAME="${APP_NAME}"

# Laravel Reverb (WebSocket)
REVERB_APP_ID=webino
REVERB_APP_KEY=webino-key
REVERB_APP_SECRET=webino-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"

# SMS OTP provider: melipayamak | parsgreen | log | stub | disabled
SMS_PROVIDER=log

# Melipayamak (REST panel)
MELIPAYAMAK_USERNAME=
MELIPAYAMAK_PASSWORD=
MELIPAYAMAK_SENDER=

# ParsGreen (optional env fallback)
PARSGREEN_API_KEY=

# Bale business bot
BALE_BOT_TOKEN=
BALE_WEBHOOK_SECRET=

# ModirPayamak (IPPanel Edge)
MODIRPAYAMAK_API_KEY=
MODIRPAYAMAK_MOCK=false

# Zarinpal (topup / payments)
ZARINPAL_MERCHANT_ID=sandbox
ZARINPAL_SANDBOX=true
